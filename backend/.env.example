NODE_ENV=development
PORT=5000
TRUST_PROXY=1
MONGO_URI=mongodb://localhost:27017/collab-workspace
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=15m
SESSION_TTL_DAYS=14
BCRYPT_SALT_ROUNDS=12
REQUEST_BODY_LIMIT=6mb
CORS_ORIGIN=http://localhost:3000,http://localhost:5173
FRONTEND_ORIGIN=http://localhost:5173
API_BASE_URL=http://localhost:5000
REFRESH_COOKIE_SAMESITE=lax
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:5000/api/auth/google/callback
GOOGLE_OAUTH_TIMEOUT_MS=10000
EMAIL_PROVIDER_URL=
EMAIL_PROVIDER_API_KEY=
EMAIL_FROM=Nexus <no-reply@example.com>
EMAIL_PROVIDER_TIMEOUT_MS=10000
PASSWORD_RESET_COOLDOWN_SECONDS=60
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_MS=30000
INVITE_TTL_DAYS=7
