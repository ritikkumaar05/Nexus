NODE_ENV=development
PORT=5000
TRUST_PROXY=1
MONGO_URI=mongodb://localhost:27017/collab-workspace
# Required only by scripts/manual-puppeteer-verification.js. Must name an isolated test DB.
TEST_DATABASE_URL=mongodb://localhost:27017/nexus-walkthrough-test
TEST_EMAIL_DOMAIN=test.nexus.local
TEST_APP_URL=http://localhost:5173
TEST_API_BASE_URL=http://localhost:5000
# Optional comma-separated production identifiers rejected by the walkthrough.
TEST_DATABASE_DENYLIST=production,prod,collab-workspace,ritikkumartestdb
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=15m
SESSION_TTL_DAYS=14
BCRYPT_SALT_ROUNDS=12
# ─── Email Verification Feature Flag ─────────────────────────────────────────
# Controls whether new accounts must verify their email before they can sign in.
#
#   false (hackathon / demo default):
#     - New accounts are created with emailVerifiedAt already set.
#     - No OTP is generated. EmailService is never called.
#     - No EMAIL_PROVIDER_URL, EMAIL_PROVIDER_API_KEY, or EMAIL_FROM needed.
#     - Login works immediately after registration.
#
#   true (production default when this key is absent or empty):
#     - New accounts must verify their email via a 6-digit OTP before login.
#     - Requires EMAIL_PROVIDER_URL, EMAIL_PROVIDER_API_KEY, and EMAIL_FROM.
#     - All existing production OTP / Resend logic is active.
#
# To re-enable for production: set to true and configure email provider below.
REQUIRE_EMAIL_VERIFICATION=false

REQUEST_BODY_LIMIT=6mb
# Optional comma-separated additional browser origins (preview URLs, alternate domains, etc.).
# Example: CORS_ORIGIN=https://preview.your-app.vercel.app,https://www.your-domain.com
CORS_ORIGIN=http://localhost:3000,http://localhost:5173
# Required canonical frontend URL used by CORS, OAuth redirects, password resets, and invite links.
# Example: FRONTEND_ORIGIN=https://your-app.vercel.app
FRONTEND_ORIGIN=http://localhost:5173
# Public URL of this backend (do not include a trailing slash).
# Example: API_BASE_URL=https://your-api.onrender.com
API_BASE_URL=http://localhost:5000
REFRESH_COOKIE_SAMESITE=lax
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:5000/api/auth/google/callback
GOOGLE_OAUTH_TIMEOUT_MS=10000
EMAIL_PROVIDER_URL=
EMAIL_PROVIDER_API_KEY=
EMAIL_FROM=Nexus <no-reply@example.com>
EMAIL_PROVIDER_TIMEOUT_MS=10000
PASSWORD_RESET_COOLDOWN_SECONDS=60
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_MS=30000
INVITE_TTL_DAYS=7
